# ── STEP 1: Groq AI (FREE) ────────────────────────────────────────────────────
# Go to console.groq.com → sign up free → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── STEP 2: SendGrid (FREE) ───────────────────────────────────────────────────
# Go to sendgrid.com → sign up free → Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# The email address you verified in SendGrid (your personal email is fine)
FROM_EMAIL=you@gmail.com

# Manager receives approval requests for student reservations (can be same email)
MANAGER_EMAIL=you@gmail.com

# ── STEP 3: Your public URL (ngrok) ──────────────────────────────────────────
# Run: npx ngrok http 3000  →  copy the https:// URL it gives you
BASE_URL=https://xxxx.ngrok-free.app

# ── Server port (leave as 3000) ───────────────────────────────────────────────
PORT=3000
