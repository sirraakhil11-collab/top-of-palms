# ─── AI Provider — choose ONE (Groq is FREE, Anthropic is paid) ──────────────
#
# OPTION 1: Groq — 100% FREE, no credit card needed
# Sign up at https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION 2: Anthropic Claude (paid, ~$5 to start)
# Get from https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Phone & SMS (Twilio) — needed only for real calls/texts ──────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+18135550000

# ── Email (SendGrid) — needed only for real emails ───────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=reservations@topofthepalms.usf.edu

# ── Manager settings ─────────────────────────────────────────────────────────
MANAGER_EMAIL=manager@topofthepalms.usf.edu

# ── Server ───────────────────────────────────────────────────────────────────
BASE_URL=https://your-ngrok-or-server-url.com
PORT=3000
RESTAURANT_PHONE=(813) 974-0000

# ── GH One POS (optional — skipped gracefully if not set) ────────────────────
GHONE_API_URL=https://api.grubhub.com/v1
GHONE_API_KEY=your_ghone_api_key
GHONE_LOCATION_ID=your_location_id
